@model SistemaGestionVentas.Models.ViewModels.ChangePasswordViewModel
@{ ViewBag.Title = "Cambiar contraseña"; }

<div class="single-box-wrapper">
    <div class="auth-box single-form-box">
        <h2 class="page-title">Cambiar contraseña</h2>
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Contraseña actual</label>
                <div class="password-field-group">
                    @Html.PasswordFor(model => model.current_password, new { @class = "form-control", maxlength = "20", id = "current_password" })
                    <button type="button" class="btn-system btn-system-neutral toggle-password" data-target="current_password">Mostrar</button>
                </div>
                <small id="current_password_counter" class="text-muted character-counter">20 caracteres restantes</small>
                @Html.ValidationMessageFor(model => model.current_password, "", new { @class = "text-danger" })
            </div>
            <div class="form-group">
                <label>Nueva contraseña</label>
                <small class="text-muted form-hint">La contraseña debe contener al menos: 8 caracteres, una mayúscula, una minúscula, un número y un símbolo.</small>
                <div class="password-field-group">
                    @Html.PasswordFor(model => model.new_password, new { @class = "form-control", maxlength = "20", id = "new_password" })
                    <button type="button" class="btn-system btn-system-neutral toggle-password" data-target="new_password">Mostrar</button>
                </div>
                <small id="new_password_counter" class="text-muted character-counter">20 caracteres restantes</small>
                @Html.ValidationMessageFor(model => model.new_password, "", new { @class = "text-danger" })
            </div>
            <div class="form-group">
                <label>Confirmar contraseña</label>
                <div class="password-field-group">
                    @Html.PasswordFor(model => model.confirm_password, new { @class = "form-control", maxlength = "20", id = "confirm_password" })
                    <button type="button" class="btn-system btn-system-neutral toggle-password" data-target="confirm_password">Mostrar</button>
                </div>
                <small id="confirm_password_counter" class="text-muted character-counter">20 caracteres restantes</small>
                @Html.ValidationMessageFor(model => model.confirm_password, "", new { @class = "text-danger" })
            </div>
            <input type="submit" value="Actualizar contraseña" class="btn-system btn-system-success auth-submit" />
            <span class="text-danger auth-error">
                @ViewBag.Error
            </span>
        }
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script src="~/Scripts/FormValidation.js"></script>
    <script src="~/Scripts/PasswordToggle.js"></script>
}
