@model IEnumerable<SistemaGestionVentas.Models.Cards>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.card_payday)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.card_payment_amount)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.card_item)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.card_state)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.card_active)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Frequencies.frequency_description)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Items.item_name)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Users.user_name)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.card_payday)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.card_payment_amount)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.card_item)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.card_state)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.card_active)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Frequencies.frequency_description)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Items.item_name)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Users.user_name)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.card_id }) |
            @Html.ActionLink("Details", "Details", new { id=item.card_id }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.card_id })
        </td>
    </tr>
}

</table>
