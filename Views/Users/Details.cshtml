@model SistemaGestionVentas.Models.ViewModels.UserDetailsViewModel
@using PagedList.Mvc

@{
    ViewBag.Title = "Información";
}

@{
    int roleId = Convert.ToInt32(Session["RoleId"]);
    int currentUserId = Convert.ToInt32(Session["UserId"]);
    bool canManage = roleId != 3 && currentUserId != Model.User.user_id;
}

<h2>Información</h2>

<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>Nombre</dt>
        <dd>@Html.DisplayFor(model => model.User.user_name)</dd>

        <dt>Apellido</dt>
        <dd>@Html.DisplayFor(model => model.User.user_lastname)</dd>

        @if (roleId != 3)
        {
            <dt>Apodo</dt>
            <dd>@Html.DisplayFor(model => model.User.user_nickname)</dd>
        }

        <dt>Número de teléfono</dt>
        <dd>@Html.DisplayFor(model => model.User.user_phone)</dd>

        <dt>Ubicación</dt>
        <dd>
            <div id="locationPreview" class="location-preview">
                @if (ViewBag.AddressLatitude != null)
                {
                    <div id="locationPreviewName" class="location-preview-name">@ViewBag.AddressName</div>
                    <div id="locationPreviewMap" class="location-preview-map" data-latitude="@ViewBag.AddressLatitude" data-longitude="@ViewBag.AddressLongitude"></div>
                    <div id="locationPreviewDescription" class="location-preview-description">@ViewBag.AddressDescription</div> }
                else
                {
                    <div id="locationPreviewPlaceholder" class="location-preview-placeholder">
                        No se encontró una ubicación.
                    </div>
                }
            </div>

            @if (ViewBag.AddressLatitude != null)
            {
                <div class="location-external-buttons">
                    <a href="https://www.google.com/maps/dir/?api=1&destination=@ViewBag.AddressLatitude,@ViewBag.AddressLongitude" target="_blank" rel="noopener" class="btn btn-default">
                        Abrir Google Maps
                    </a>
                    <a id="btnWazeLink" href="https://waze.com/ul?ll=@ViewBag.AddressLatitude,@ViewBag.AddressLongitude&navigate=yes" target="_blank" rel="noopener" class="btn btn-default">
                        Abrir Waze
                    </a>
                </div>
            }
        </dd>

        <dt>Correo electrónico</dt>
        <dd>@Html.DisplayFor(model => model.User.user_email)</dd>

        @if (roleId != 3)
        {
            <dt>Estado</dt>
            <dd>@(Model.User.user_active ? "Activo" : "Inactivo")</dd>

            <dt>Tipo de usuario</dt>
            <dd>@Html.DisplayFor(model => model.User.Roles.role_description)</dd>
        }
    </dl>
</div>
<p>
    @if (canManage)
    {
        @Html.ActionLink("Editar", "Edit", new { id = Model.User.user_id })
    }
</p>

<h3>Tarjetas del usuario</h3>

@if (canManage)
{
    <p>
        @Html.ActionLink("Registrar tarjeta", "Create", "Cards", new { userId = Model.User.user_id }, null)
    </p>
}

@using (Html.BeginForm("Details", "Users", FormMethod.Get))
{
    @Html.Hidden("id", Model.User.user_id)

    <div class="row">

        <div class="col-md-3">
            <label>Día de pago</label>
            <input type="text" name="card_payday" value="@Model.CardPaydayFilter" class="form-control" maxlength="50" />
        </div>

        <div class="col-md-2">
            <label>Periodicidad</label>
            @Html.DropDownList("frequency_id", (SelectList)ViewBag.frequency_id, "Todas", new { @class = "form-control" })
        </div>

        <div class="col-md-2">
            <label>Estado</label>
            <select name="card_state" class="form-control">
                <option value="">Todos</option>
                <option value="true" @(Request["card_state"] == "true" ? "selected" : "")>Vigente</option>
                <option value="false" @(Request["card_state"] == "false" ? "selected" : "")>Cancelada</option>
            </select>
        </div>

        @if (Convert.ToInt32(Session["RoleId"]) != 3)
        {
            <div class="col-md-2">
                <label>Activo</label>
                <select name="card_active" class="form-control">
                    <option value="">Todos</option>
                    <option value="true" @(Request["card_active"] == "true" ? "selected" : "")>Activo</option>
                    <option value="false" @(Request["card_active"] == "false" ? "selected" : "")>Inactivo</option>
                </select>
            </div>}

        <div class="col-md-2">
            <label>&nbsp;</label>
            <div>
                <input type="submit" value="Buscar" class="btn btn-primary" />
                <a href="@Url.Action("Details", "Users", new { id = Model.User.user_id })" class="btn btn-default">Limpiar</a>
            </div>
        </div>
    </div>

    <br />
}

<table class="table">
    <tr>
        <th>Día de pago</th>
        <th>Periodicidad</th>
        <th>Artículo</th>
        <th>Precio del artículo</th>
        <th>Estado</th>
        @if (roleId != 3)
        {
            <th>Activo</th>
        }
        <th></th>
    </tr>

    @foreach (var card in Model.Cards)
    {
        <tr>
            <td>@card.card_payday</td>
            <td>@card.Frequencies.frequency_description</td>
            <td>@card.card_item</td>
            <td>@card.card_item_price</td>
            <td>@(card.card_state ? "Vigente" : "Cancelada")</td>
            @if (roleId != 3)
            {
                <td>@(card.card_active ? "Activo" : "Inactivo")</td>
            }

            <td>
                @if (canManage)
                {
                    @Html.ActionLink("Editar", "Edit", "Cards", new { id = card.card_id }, null) @: |
                }
                @Html.ActionLink("Ver cobros", "Details", "Cards", new { id = card.card_id }, null)
                @if (card.card_active)
                {
                    if (canManage)
                    {
                        @: |
                        @Html.ActionLink("Desactivar", "Delete", "Cards", new { id = card.card_id }, null)
                    }
                }
                else
                {
                    if (roleId == 1)
                    {
                        @: |
                        @Html.ActionLink("Reactivar", "Reactivate", "Cards", new { id = card.card_id }, null)
                    }
                }
            </td>
        </tr>
    }

</table>

@Html.PagedListPager(Model.Cards, page => Url.Action("Details", new
{
    id = Model.User.user_id,
    page,
    card_payday = Request["card_payday"],
    frequency_id = Request["frequency_id"],
    card_state = Request["card_state"],
    card_active = Request["card_active"]
}))

<p>
    @if (roleId != 3)
    {
        @Html.ActionLink("Atrás", "Index")
    }
</p>

@section Scripts {
    <script src="~/Scripts/Location/LocationDetailsPreview.js"></script>
    <script src="~/Scripts/Location/LocationExternalApps.js"></script>
}