@model SistemaGestionVentas.Models.Users
@{
    ViewBag.Title = "Desactivar usuario";
}

<h2 class="page-title page-title-centered page-title-danger">Desactivar usuario</h2>

<div class="single-box-wrapper">
    <div class="auth-box single-form-box">

        <div class="warning-box warning-box-danger">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>¿Está seguro de desactivar a este usuario?</span>
        </div>

        <div class="info-list">
            <div class="info-row">
                <div class="info-label">Nombre</div>
                <div class="info-value">@Html.DisplayFor(model => model.user_name)</div>
            </div>
            <div class="info-row">
                <div class="info-label">Apellido</div>
                <div class="info-value">@Html.DisplayFor(model => model.user_lastname)</div>
            </div>
            <div class="info-row">
                <div class="info-label">Apodo</div>
                <div class="info-value">@Html.DisplayFor(model => model.user_nickname)</div>
            </div>
            <div class="info-row">
                <div class="info-label">Número telefónico</div>
                <div class="info-value">@Html.DisplayFor(model => model.user_phone)</div>
            </div>
            <div class="info-row">
                <div class="info-label">Correo electrónico</div>
                <div class="info-value">@Html.DisplayFor(model => model.user_email)</div>
            </div>
            <div class="info-row info-row-last">
                <div class="info-label">Tipo de usuario</div>
                <div class="info-value">@Html.DisplayFor(model => model.Roles.role_description)</div>
            </div>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <div class="form-page-actions-row">
                <input type="submit" value="Desactivar" class="btn-system btn-system-danger" />
                @Html.ActionLink("Atrás", "Index", null, new { @class = "btn-system btn-system-neutral" })
            </div>
        }
    </div>
</div>
