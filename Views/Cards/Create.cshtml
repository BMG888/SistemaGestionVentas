@model SistemaGestionVentas.Models.Cards

@{
    ViewBag.Title = "Registrar tarjeta";
}

<h2>Registrar tarjeta</h2>


@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.Hidden("userId", (int)ViewBag.UserId)

    <div class="form-horizontal">
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <div class="form-group">
            @Html.Label("Día de pago", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.card_payday, new { htmlAttributes = new { @class = "form-control", maxlength = "50", id = "card_payday" } })
                <small id="card_payday_counter" class="text-muted character-counter">50 caracteres restantes</small>
                @Html.ValidationMessageFor(model => model.card_payday, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Monto por pagar", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                <small class="text-muted">Solo se permiten números.</small>
                @Html.EditorFor(model => model.card_payment_amount, new { htmlAttributes = new { @class = "form-control", type = "number", min = "1" } })
                @Html.ValidationMessageFor(model => model.card_payment_amount, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Frecuencia de pago", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownList("frequency_id", null, htmlAttributes: new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.frequency_id, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Descripción del artículo", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.card_item, new { htmlAttributes = new { @class = "form-control", maxlength = "100", id = "card_item" } })
                <small id="card_item_counter" class="text-muted character-counter">100 caracteres restantes</small>
                @Html.ValidationMessageFor(model => model.card_item, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Precio del artículo", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                <small class="text-muted">Solo se permiten números.</small>
                @Html.EditorFor(model => model.card_item_price, new { htmlAttributes = new { @class = "form-control", type = "number", min = "1" } })
                @Html.ValidationMessageFor(model => model.card_item_price, "", new { @class = "text-danger" })
            </div>
        </div>

        @*<div class="form-group">
                @Html.Label("Imagen del artículo", "item_id", htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.DropDownList("item_id", null, htmlAttributes: new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.item_id, "", new { @class = "text-danger" })
                </div>
            </div>*@

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Registrar" class="btn btn-default" />
            </div>
        </div>
    </div>
}

<div>
    @Html.ActionLink("Atrás", "Details", "Users", new { id = ViewBag.UserId }, null)
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script src="~/Scripts/FormValidation.js"></script>
}
