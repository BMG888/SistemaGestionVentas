                @Html.EditorFor(model => model.item_url, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.item_url, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
