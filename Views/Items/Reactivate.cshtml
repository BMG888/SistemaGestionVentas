@model SistemaGestionVentas.Models.Items
@{
    ViewBag.Title = "Reactivar producto";
}

<h2 class="page-title page-title-centered page-title-success">Reactivar producto</h2>

<div class="single-box-wrapper">
    <div class="auth-box single-form-box">

        <div class="warning-box warning-box-success">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>¿Está seguro de reactivar este producto?</span>
        </div>

        <div class="info-list">
            <div class="info-row">
                <div class="info-label">Nombre del producto</div>
                <div class="info-value">@Html.DisplayFor(model => model.item_name)</div>
            </div>
            <div class="info-row info-row-inline">
                <div class="info-label">Imagen</div>
                <div class="info-value">
                    <div class="info-image-box">
                        <img src="@Url.Content(Model.item_url)" alt="Imagen del artículo" />
                    </div>
                </div>
            </div>
            <div class="info-row">
                <div class="info-label">Descripción del producto</div>
                <div class="info-value">@Html.DisplayFor(model => model.item_description)</div>
            </div>
            <div class="info-row">
                <div class="info-label">Álbum</div>
                <div class="info-value">@Html.DisplayFor(model => model.Albums.album_name)</div>
            </div>
            <div class="info-row info-row-last">
                <div class="info-label">Estado</div>
                <div class="info-value">@(Model.item_active ? "Activo" : "Inactivo")</div>
            </div>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <div class="form-page-actions-row">
                <input type="submit" value="Reactivar" class="btn-system btn-system-success" />
                @Html.ActionLink("Atrás", "Details", "Albums", new { id = Model.album_id }, new { @class = "btn-system btn-system-neutral" })
            </div>
        }
    </div>
</div>