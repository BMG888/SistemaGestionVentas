<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Distribuidora La Bendición S.A</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&family=Poppins:wght@400;500;600&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/Content/bootstrap_icons/bootstrap-icons.css" />
    @Styles.Render("~/Content/css")
    <link rel="stylesheet" href="~/Content/leaflet/leaflet.css" />
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <div class="navbar navbar-inverse navbar-fixed-top">
        <div class="container">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                <a class="navbar-brand brand-title" href="@Url.Action("Index", "Home")">
                    <span class="brand-title-top">Distribuidora</span>
                    <span class="brand-title-main">La Bendición <span class="brand-title-sa">S.A</span></span>
                </a>
            </div>
            <div class="navbar-collapse collapse">
                <ul class="nav navbar-nav">
                    <li>@Html.ActionLink("Inicio", "Index", "Home")</li>
                    @if (Session["UserId"] != null)
                    {
                        int roleId = Convert.ToInt32(Session["RoleId"]);
                        if (roleId == 3)
                        {
                            <li>@Html.ActionLink("Perfil", "Details", "Users", new { id = Session["UserId"] }, null)</li>
                        }
                        else
                        {
                            <li>@Html.ActionLink("Usuarios", "Index", "Users")</li>
                        }
                    }
                    <li>@Html.ActionLink("Productos", "Index", "Albums")</li>
                </ul>
                <ul class="nav navbar-nav navbar-right">
                    @if (Session["UserId"] == null)
                    {
                        <li>@Html.ActionLink("Iniciar sesión", "Login", "Auth")</li>
                    }
                    else
                    {
                        <li><a href="#">@Session["UserName"]</a></li>
                        <li>@Html.ActionLink("Cambiar contraseña", "ChangePassword", "Auth")</li>
                        <li>@Html.ActionLink("Cerrar sesión", "Logout", "Auth")</li>
                    }
                </ul>
            </div>
        </div>
    </div>
    <div class="container body-content">
        @RenderBody()
        <footer class="site-footer">
            <div class="footer-content">
                <div class="footer-item">
                    <i class="bi bi-person-fill"></i>
                    <span>Mauricio Méndez Orozco</span>
                </div>
                <div class="footer-item">
                    <i class="bi bi-telephone-fill"></i>
                    <span>+506 8820-1600</span>
                </div>
                <div class="footer-item">
                    <i class="bi bi-geo-alt-fill"></i>
                    <span>Opera principalmente en San José, Costa Rica</span>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; @DateTime.Now.Year - Desarrollado por Bryan Méndez Garita</p>
            </div>
        </footer>
    </div>
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/Scripts/Alerts.js"></script>
    <script src="~/Scripts/leaflet/leaflet.js"></script>
    @if (TempData["Success"] != null)
    {
        <script>showSuccess(@Html.Raw(Json.Encode(TempData["Success"])));</script>
    }
    @if (TempData["Error"] != null)
    {
        <script>showError(@Html.Raw(Json.Encode(TempData["Error"])));</script>
    }
    @if (TempData["Warning"] != null)
    {
        <script>showWarning(@Html.Raw(Json.Encode(TempData["Warning"])));</script>
    }
    @RenderSection("scripts", required: false)
</body>
</html>