@model SistemaGestionVentas.Models.Users

@{
    ViewBag.Title = "Reactivar usuario";
}

<h2>Reactivar usuario</h2>

<h3>¿Está seguro de reactivar a este usuario?</h3>
<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>Nombre</dt>
        <dd>@Html.DisplayFor(model => model.user_name)</dd>

        <dt>Apellido</dt>
        <dd>@Html.DisplayFor(model => model.user_lastname)</dd>

        <dt>Apodo</dt>
        <dd>@Html.DisplayFor(model => model.user_nickname)</dd>

        <dt>Número telefónico</dt>
        <dd>@Html.DisplayFor(model => model.user_phone)</dd>

        <dt>Correo electrónico</dt>
        <dd>@Html.DisplayFor(model => model.user_email)</dd>

        <dt>Tipo de usuario</dt>
        <dd>@Html.DisplayFor(model => model.Roles.role_description)</dd>

    </dl>

    @using (Html.BeginForm()) {
        @Html.AntiForgeryToken()

        <div class="form-actions no-color">
            <input type="submit" value="Reactivar" class="btn btn-default" /> |
            @Html.ActionLink("Atrás", "Index")
        </div>
    }
</div>
