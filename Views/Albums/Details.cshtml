@model SistemaGestionVentas.Models.Albums

@{
    ViewBag.Title = "Details";
}

<h2>Details</h2>
<div>
    <h4>Albums</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayNameFor(model => model.album_name)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.album_name)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.album_active)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.album_active)
        </dd>

    </dl>
</div>
<p>
    @Html.ActionLink("Edit", "Edit", new { id = Model.album_id })
</p>

<h3>Items del álbum</h3>
<p>
    @Html.ActionLink("Agregar Item", "Create", "Items")
</p>
<table class="table">
    <tr>        
        <th>Nombre</th>
        <th>URL</th>
        <th>Descripción</th>
        <th>Activo</th>
        <th></th>
    </tr>

    @foreach (var item in Model.Items)
    {
<tr>    
    <td>@item.item_name</td>
    <td>@item.item_url</td>
    <td>@item.item_description</td>
    <td>@item.item_active</td>

    <td>
        @Html.ActionLink("Editar", "Edit", "Items", new { id = item.item_id }, null) |
        @Html.ActionLink("Detalles", "Details", "Items", new { id = item.item_id }, null) |
        @Html.ActionLink("Eliminar", "Delete", "Items", new { id = item.item_id }, null)
    </td>
</tr>}

</table>

<p>
    @Html.ActionLink("Back to List", "Index")
</p>
