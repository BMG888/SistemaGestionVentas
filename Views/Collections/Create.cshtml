@model SistemaGestionVentas.Models.Collections

@{
    ViewBag.Title = "Registrar cobro";
}

<h2>Registrar cobro</h2>


@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        @Html.HiddenFor(model => model.card_id)
        <div class="form-group">
            @Html.Label("Monto", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                <small class="text-muted">Solo se permiten números.</small>
                @Html.EditorFor(model => model.collection_amount, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0" } })
                @Html.ValidationMessageFor(model => model.collection_amount, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Nota", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                <small class="text-muted">Si el monto es "0" o es un ajuste, la nota es obligatoria.</small>
                @Html.EditorFor(model => model.collection_note, new { htmlAttributes = new { @class = "form-control", maxlength = "255", id = "collection_note" } })
                <small id="collection_note_counter" class="text-muted character-counter">255 caracteres restantes</small>
                @Html.ValidationMessageFor(model => model.collection_note, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Registrar" class="btn btn-default" />
            </div>
        </div>
    </div>
}

<div>
    @Html.ActionLink("Atrás", "Details", "Cards", new { id = Model.card_id }, null)
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script src="~/Scripts/FormValidation.js"></script>
}
