@model SistemaGestionVentas.Models.Cards

@{
    ViewBag.Title = "Reactivar tarjeta";
}

<h2>Reactivar tarjeta</h2>

<h3>¿Está seguro de reactivar esta tarjeta?</h3>
<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>Día de pago</dt>
        <dd>@Html.DisplayFor(model => model.card_payday)</dd>

        <dt>Monto por pagar</dt>
        <dd>@Html.DisplayFor(model => model.card_payment_amount)</dd>

        <dt>Frecuencia de pago</dt>
        <dd>@Html.DisplayFor(model => model.Frequencies.frequency_description)</dd>

        <dt>Descripción del artículo</dt>
        <dd>@Html.DisplayFor(model => model.card_item)</dd>

        <dt>Precio del artículo</dt>
        <dd>@Html.DisplayFor(model => model.card_item_price)</dd>

        <dt>Vigencia</dt>
        <dd>@Html.DisplayFor(model => model.card_state)</dd>

        @*<dt>Imagen del artículo</dt>
            <dd>@Html.DisplayFor(model => model.Items.item_name)</dd>*@
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-actions no-color">
            <input type="submit" value="Reactivar" class="btn btn-default" /> |
            @Html.ActionLink("Atrás", "Details", "Users", new { id = Model.user_id }, null)
        </div>
    }
</div>