@model SistemaGestionVentas.Models.ViewModels.AlbumDetailsViewModel
@using PagedList.Mvc
@{
    ViewBag.Title = "Productos";
}
@{
    int roleId = Session["RoleId"] != null ? Convert.ToInt32(Session["RoleId"]) : 0;
    bool canManage = roleId == 1 || roleId == 2;
}

<h2 class="page-title page-title-centered">Productos</h2>

<div class="details-box details-box-single">
    <div class="details-info-column">
        <div class="details-row @(canManage ? "" : "details-row-last")">
            <div class="details-label"><i class="bi bi-collection-fill"></i> Nombre del álbum</div>
            <div class="details-value">@Html.DisplayFor(model => model.Album.album_name)</div>
        </div>
        @if (canManage)
        {
            <div class="details-row details-row-last">
                <div class="details-label"><i class="bi bi-toggle-on"></i> Estado</div>
                <div class="details-value">@(Model.Album.album_active ? "Activo" : "Inactivo")</div>
            </div>
        }
    </div>

    @if (canManage)
    {
        <div class="details-actions">
            @Html.ActionLink("Editar álbum", "Edit", new { id = Model.Album.album_id }, new { @class = "btn-system btn-system-filter" })
        </div>
    }
</div>

<h3 class="section-title">Fotos del álbum</h3>

@if (canManage)
{
    <p class="index-actions">
        @Html.ActionLink("Agregar producto", "Create", "Items", new { albumId = Model.Album.album_id }, new { @class = "btn-system btn-system-neutral" })
    </p>
}

<div class="filter-box">
    @using (Html.BeginForm("Details", "Albums", FormMethod.Get))
    {
        @Html.Hidden("id", Model.Album.album_id)

        <div class="filter-grid">
            <div class="filter-field">
                <label>Nombre</label>
                <input type="text" name="item_name" value="@Model.ItemNameFilter" class="form-control" />
            </div>

            @if (canManage)
            {
                <div class="filter-field">
                    <label>Estado</label>
                    <select name="item_active" class="form-control">
                        <option value="">Todos</option>
                        <option value="true" @(Request["item_active"] == "true" ? "selected" : "")>Activo</option>
                        <option value="false" @(Request["item_active"] == "false" ? "selected" : "")>Inactivo</option>
                    </select>
                </div>
            }

            <div class="filter-field filter-field-actions">
                <label class="filter-label-spacer">&nbsp;</label>
                <div class="filter-buttons">
                    <input type="submit" value="Buscar" class="btn-system btn-system-filter" />
                    <a href="@Url.Action("Details", new { id = Model.Album.album_id })" class="btn-system btn-system-filter">Limpiar</a>
                </div>
            </div>
        </div>
    }
</div>

<div class="item-grid">
    @foreach (var item in Model.Items)
    {
    <div class="item-card">
        <div class="item-card-header">
            <span class="item-card-name">@item.item_name</span>
            @if (canManage)
            {
                if (item.item_active)
                {
                    <span class="badge badge-success">Activo</span>
                }
                else
                {
                    <span class="badge badge-default">Inactivo</span>
                }
            }
        </div>

        <div class="item-image-wrapper">
            <img src="@Url.Content(item.item_url)" alt="@item.item_name" class="item-card-image" />

            <div class="album-overlay">
                <div class="album-overlay-bg"></div>
                <div class="album-overlay-actions">
                    @if (canManage)
                    {
                        @Html.ActionLink("Editar", "Edit", "Items", new { id = item.item_id }, new { @class = "btn-system btn-system-neutral" })
                    }
                    @Html.ActionLink("Descripción", "Details", "Items", new { id = item.item_id }, new { @class = "btn-system btn-system-neutral" })
                    @if (canManage)
                    {
                        if (item.item_active)
                        {
                            @Html.ActionLink("Desactivar", "Delete", "Items", new { id = item.item_id }, new { @class = "btn-system btn-system-danger" })
                        }
                        else if (roleId == 1)
                        {
                            @Html.ActionLink("Reactivar", "Reactivate", "Items", new { id = item.item_id }, new { @class = "btn-system btn-system-success" })
                        }
                    }
                </div>
            </div>
        </div>
    </div>
    }
</div>

<div class="pagination-wrapper">
    @Html.PagedListPager(Model.Items, page => Url.Action("Details", new
             {
                 id = Model.Album.album_id,
                 page,
                 item_name = Request["item_name"],
                 item_active = Request["item_active"]
             }))
</div>

<div class="back-only-row">
    @Html.ActionLink("Atrás", "Index", null, new { @class = "btn-system btn-system-neutral" })
</div>

@section Scripts {
    <script src="~/Scripts/Albums/AlbumCardOverlay.js"></script>
}