@model SistemaGestionVentas.Models.Albums

@{
    ViewBag.Title = "Desactivar";
}

<h2>Desactivar álbum</h2>

<h3>¿Está seguro de desactivar este álbum?</h3>
<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>Nombre del álbum</dt>
        <dd>@Html.DisplayFor(model => model.album_name)</dd>

        <dt>Estado</dt>
        <dd>@(Model.album_active ? "Activo" : "Inactivo")</dd>

    </dl>

    @using (Html.BeginForm()) {
        @Html.AntiForgeryToken()

        <div class="form-actions no-color">
            <input type="submit" value="Desactivar" class="btn btn-default" /> |
            @Html.ActionLink("Atrás", "Index")
        </div>
    }
</div>
