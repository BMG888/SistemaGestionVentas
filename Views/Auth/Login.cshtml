@model SistemaGestionVentas.Models.ViewModels.LoginViewModel
@{
    ViewBag.Title = "Iniciar sesión";
}

<h2>Iniciar sesión</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label>Correo electrónico</label>
        @Html.TextBoxFor(model => model.user_email, new { @class = "form-control", maxlength = "150", id = "login_email" })
        <small id="login_email_counter" class="text-muted character-counter">150 caracteres restantes</small>
        @Html.ValidationMessageFor(model => model.user_email, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        <label>Contraseña</label>
        <div style="display:flex; gap:10px;">
            @Html.PasswordFor(model => model.user_password, new { @class = "form-control", maxlength = "20", id = "login_password" })
            <button type="button" class="btn btn-default toggle-password" data-target="login_password">Mostrar</button>
        </div>
        <small id="login_password_counter" class="text-muted character-counter">20 caracteres restantes</small>
        @Html.ValidationMessageFor(model => model.user_password, "", new { @class = "text-danger" })
    </div>
    <br />

    <input type="submit" value="Iniciar sesión" class="btn btn-primary" />

    <br />
    <br />

    <span class="text-danger">
        @ViewBag.Error
    </span>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script src="~/Scripts/FormValidation.js"></script>
    <script src="~/Scripts/PasswordToggle.js"></script>
}
