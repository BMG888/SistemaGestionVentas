@model SistemaGestionVentas.Models.Albums
@{
    ViewBag.Title = "Reactivar álbum";
}

<h2 class="page-title page-title-centered page-title-success">Reactivar álbum</h2>

<div class="single-box-wrapper">
    <div class="auth-box single-form-box">

        <div class="warning-box warning-box-success">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>¿Está seguro de reactivar este álbum?</span>
        </div>

        <div class="info-list">
            <div class="info-row">
                <div class="info-label">Nombre del álbum</div>
                <div class="info-value">@Html.DisplayFor(model => model.album_name)</div>
            </div>
            <div class="info-row info-row-last">
                <div class="info-label">Estado</div>
                <div class="info-value">@(Model.album_active ? "Activo" : "Inactivo")</div>
            </div>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <div class="form-page-actions-row">
                <input type="submit" value="Reactivar" class="btn-system btn-system-success" />
                @Html.ActionLink("Atrás", "Index", null, new { @class = "btn-system btn-system-neutral" })
            </div>
        }
    </div>
</div>