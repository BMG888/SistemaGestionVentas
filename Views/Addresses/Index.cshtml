@model IEnumerable<SistemaGestionVentas.Models.Addresses>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.address_name)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.address_latitude)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.address_longitude)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.address_description)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.address_active)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Users.user_name)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.address_name)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.address_latitude)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.address_longitude)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.address_description)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.address_active)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Users.user_name)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.address_id }) |
            @Html.ActionLink("Details", "Details", new { id=item.address_id }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.address_id })
        </td>
    </tr>
}

</table>
