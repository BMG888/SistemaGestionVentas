@model SistemaGestionVentas.Models.Items
@{
    ViewBag.Title = "Editar producto";
}

<h2 class="page-title page-title-centered">Editar producto</h2>

<div class="form-page-wrapper">
    <div class="auth-box form-page-box">
        @using (Html.BeginForm(null, null, FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(model => model.item_id)
            @Html.HiddenFor(model => model.item_url)

            <div class="form-horizontal card-form-columns">

                <div class="card-form-left">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="form-group">
                        @Html.Label("Nombre del producto", htmlAttributes: new { @class = "control-label col-md-2" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.item_name, new { htmlAttributes = new { @class = "form-control", maxlength = "100", id = "edit_item_name" } })
                            <small id="edit_item_name_counter" class="text-muted character-counter">100 caracteres restantes</small>
                            <div class="validation-space">
                                @Html.ValidationMessageFor(model => model.item_name, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        @Html.Label("Descripción del producto", htmlAttributes: new { @class = "control-label col-md-2" })
                        <div class="col-md-10">
                            @Html.TextAreaFor(model => model.item_description, new { @class = "form-control", maxlength = "255", id = "edit_item_description" })
                            <small id="edit_item_description_counter" class="text-muted character-counter">255 caracteres restantes</small>
                            <div class="validation-space">
                                @Html.ValidationMessageFor(model => model.item_description, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        @Html.Label("Cambiar álbum", htmlAttributes: new { @class = "control-label col-md-2" })
                        <div class="col-md-10">
                            @Html.DropDownList("album_id", null, htmlAttributes: new { @class = "form-control" })
                            <div class="validation-space">
                                @Html.ValidationMessageFor(model => model.album_id, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-form-right">
                    <div class="form-group">
                        @Html.Label("Imagen", htmlAttributes: new { @class = "control-label col-md-2" })
                        <div class="col-md-10">
                            <small class="text-muted form-hint">Si selecciona una nueva imagen, reemplazará la actual. Formatos permitidos: JPG, JPEG, PNG y WEBP.</small>

                            <div id="itemImagePreview" class="image-preview-box">
                                <div class="image-preview-placeholder">
                                    <i class="bi bi-image"></i>
                                    <span>No se ha seleccionado ninguna imagen.</span>
                                </div>
                                <img id="itemImagePreviewImg" class="image-preview-img" src="@Url.Content(Model.item_url)" alt="Vista previa" />
                            </div>

                            <div class="item-file-input-wrapper">
                                <input type="file" id="imageFileInput" name="imageFile" accept=".jpg,.jpeg,.png,.webp" class="form-control" />
                            </div>

                            <div class="validation-space">
                                @Html.ValidationMessageFor(model => model.item_url, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-page-actions-row">
                    <input type="submit" value="Actualizar" class="btn-system btn-system-success" />
                    @Html.ActionLink("Atrás", "Details", "Albums", new { id = Model.album_id }, new { @class = "btn-system btn-system-neutral" })
                </div>

            </div>
        }
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script src="~/Scripts/FormValidation.js"></script>
    <script src="~/Scripts/Items/ItemImagePreview.js"></script>
}
